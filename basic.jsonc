{
  // Devcontainer for VS Code / Codespaces
  "name": "my-dev",
  /* Multi-line
     comment */
  "image": "mcr.microsoft.com/devcontainers/go:3.21",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "docker.io/myorg/web:3.0.0"
    },
    {
      "name": "non-semver",
      "image": "docker.io/library/ubuntu:latest"
    },
    {
      "name": "short-form",
      "image": "nginx:1.21"
    }
  ]
}
