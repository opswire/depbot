# Application
APP_PORT=8080
NODE_ENV=production
TIMEOUT=30s

# Images (with explicit domains)
APP_IMAGE=docker.io/myorg/app:3.1.0
DOCKER_BASE=docker.io/library/alpine:3.19
export NGINX_IMAGE="gcr.io/distroless/nginx:3.25.0"
DB_PASSWORD="not-an-image"

# Short-form, skipped (no explicit domain):
SHORT_FORM_IMAGE=traefik:3.0

# Non-semver tag, skipped:
PROXY_IMAGE=docker.io/library/traefik:latest

# Templated, skipped:
DEV_IMAGE=${BASE}:${TAG}

# host:port should not match:
DB_HOST=db.example.com:5432
DOCKER_REGISTRY=registry.example.com:5000
